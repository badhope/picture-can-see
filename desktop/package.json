{
  "name": "picture-can-see-desktop",
  "version": "1.0.0",
  "description": "Picture Can See - 数据可视化桌面应用",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "postinstall": "electron-builder install-app-deps"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/badhope/picture-can-see.git",
    "directory": "desktop"
  },
  "bugs": {
    "url": "https://github.com/badhope/picture-can-see/issues"
  },
  "homepage": "https://github.com/badhope/picture-can-see#readme",
  "author": "Picture Can See Team",
  "license": "MIT",
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "d3": "^7.8.5",
    "xlsx": "^0.18.5"
  },
  "build": {
    "appId": "com.picturecansee.desktop",
    "productName": "Picture Can See",
    "copyright": "Copyright © 2024 Picture Can See Team",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "styles/**/*",
      "locales/**/*",
      "assets/**/*",
      "index.html"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "artifactName": "${productName}-${version}-${arch}-setup.${ext}"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        },
        {
          "target": "zip",
          "arch": ["x64", "arm64"]
        }
      ],
      "category": "public.app-category.productivity",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        },
        {
          "target": "deb",
          "arch": ["x64"]
        }
      ],
      "category": "Office",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  }
}
