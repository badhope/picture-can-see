{
  "name": "picture-can-see",
  "version": "1.0.0",
  "description": "A powerful, intuitive data visualization tool that transforms raw data into beautiful charts with minimal effort. Supports CSV, Excel, JSON, and more. Available as web app and desktop application for Windows, macOS, and Linux.",
  "private": false,
  "workspaces": [
    "web",
    "desktop"
  ],
  "scripts": {
    "web": "npm run start -w web",
    "desktop": "npm run start -w desktop",
    "desktop:build": "npm run build -w desktop",
    "desktop:build:win": "npm run build:win -w desktop",
    "desktop:build:mac": "npm run build:mac -w desktop",
    "desktop:build:linux": "npm run build:linux -w desktop",
    "install:all": "npm install",
    "clean": "rimraf node_modules web/node_modules desktop/node_modules desktop/dist",
    "clean:cache": "rimraf node_modules/.cache",
    "lint": "echo 'Linting not configured yet'",
    "format": "echo 'Formatting not configured yet'",
    "test": "echo 'Tests not configured yet'"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/badhope/picture-can-see.git"
  },
  "bugs": {
    "url": "https://github.com/badhope/picture-can-see/issues"
  },
  "homepage": "https://github.com/badhope/picture-can-see#readme",
  "keywords": [
    "data-visualization",
    "chart",
    "charts",
    "d3",
    "d3js",
    "electron",
    "csv",
    "excel",
    "json",
    "visualization",
    "chart-generator",
    "data-analysis",
    "graph",
    "plot",
    "bar-chart",
    "line-chart",
    "pie-chart",
    "scatter-plot",
    "radar-chart",
    "area-chart",
    "desktop-app",
    "cross-platform",
    "offline",
    "privacy-first",
    "drag-and-drop",
    "smart-recommendation",
    "export",
    "png",
    "svg",
    "pdf",
    "html",
    "typescript-free",
    "zero-dependency",
    "open-source",
    "mit-license"
  ],
  "author": "Picture Can See Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "devDependencies": {
    "rimraf": "^5.0.5"
  }
}
